# Supabase — published-content reads only (anon key; the service-role key
# must NEVER exist in this repo or its Vercel project).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Shared secret the Hous Panel sends in x-revalidate-secret when publishing.
REVALIDATE_SECRET=

# Rollback: unset the two Supabase vars and redeploy — the site pins itself
# to content/seed.json and logs [content-fallback] warnings.
